doctype html

tg-project-archived-warning
div.wrapper(ng-init="section='backlog'")
    tg-project-menu

    //- React 18 in-place migration: the Backlog / sprint-planning screen is now
    //- owned by the React `BacklogApp` container, hosted here as the
    //- `<tg-react-backlog>` Custom Element (registered by app/react/index.tsx via
    //- app/react/shared/mount.tsx; the react.js bundle loads before angular.bootstrap).
    //- Lower-kebab attributes are bridged to camelCase React props ("props down");
    //- React self-resolves the project from URL/session, so empty values are safe.
    tg-react-backlog(
        project-id="{{ project.id }}"
        project-slug="{{ project.slug }}"
    )
