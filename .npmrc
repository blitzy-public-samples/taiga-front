# ---------------------------------------------------------------------------
# npm configuration for the taiga-front build.
#
# Dependency-security mitigation for finding M11 (Playwright advisory
# GHSA-7mvr-c777-76hp). The Node 16.19.1 runtime pin (.nvmrc) prevents upgrading
# @playwright/test past the 1.44.x line (1.45 drops Node 16), so the accepted
# mitigation is to NOT download Playwright's bundled browser drivers and to drive
# the parity suite with the TRUSTED pre-installed Google Chrome instead
# (playwright.config.ts sets `channel: "chrome"` on every project).
#
# Playwright's installer reads this key via getFromENV's npm_config fallback
# (node_modules/playwright-core/lib/utils/env.js): `npm ci` / `npm install`
# exposes it as `npm_config_playwright_skip_browser_download`, so the bundled
# Chromium / WebKit / Firefox drivers are never fetched.
# ---------------------------------------------------------------------------
playwright_skip_browser_download=1
